# Copy to .env on the server (same directory as docker-compose.prod.yml).
# Used at docker compose build time for NEXT_PUBLIC_* (baked into the client bundle).
NEXT_PUBLIC_API_URL=

# IANA timezone for all school-facing dates/times (must match backend DJANGO_TIME_ZONE / TIME_ZONE).
NEXT_PUBLIC_APP_TIME_ZONE=Asia/Almaty
